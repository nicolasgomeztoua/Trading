# Tradovate API Credentials
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_APP_ID=ETradesScalp
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=0
TRADOVATE_SECRET=your_api_secret
TRADOVATE_USE_DEMO=true

# Webhook Server
WEBHOOK_PORT=8765
WEBHOOK_SECRET=          # optional: set a secret to validate incoming webhooks
RISK_DOLLARS=2000        # full DD risk per trade
MAX_CONTRACTS=60         # Lucid 100K = 60 micro max

# Bot Config (if using the standalone bot instead of webhook)
SYMBOL=MNQ
RISK_PCT=1.0
SIZE_MODE=Fixed $
FIXED_CONTRACTS=1
TP_R_MULTIPLE=0.2
REVERSAL_LOOKBACK=30
