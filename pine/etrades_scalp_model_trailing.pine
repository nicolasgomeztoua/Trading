//@version=5
strategy("ETrades Scalp Model [Trailing]", overlay=true, calc_on_every_tick=false, process_orders_on_close=true,
     initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1,
     pyramiding=0, commission_type=strategy.commission.cash_per_contract, commission_value=2.50,
     max_boxes_count=500, max_labels_count=500, max_lines_count=500)

// ══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════════════════

// Setup Toggles
i_enableSetup1 = input.bool(true, "Enable Setup 1: Double Gap", group="Setup Toggles")
i_enableSetup2 = input.bool(true, "Enable Setup 2: Reversal", group="Setup Toggles")
i_enableSetup3 = input.bool(true, "Enable Setup 3: Continuation", group="Setup Toggles")
i_enableSetup4 = input.bool(true, "Enable Setup 4: Tap & Engulf", group="Setup Toggles")

// Risk Management
i_sizeMode      = input.string("Risk %", "Position Sizing Mode", options=["Risk %", "Fixed $", "Fixed contracts"], group="Risk Management")
i_riskPct       = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=10, step=0.1, group="Risk Management")
i_riskDollars   = input.float(250.0, "Risk Per Trade ($)", minval=10, step=50, group="Risk Management")
i_fixedContracts = input.int(1, "Fixed Contracts", minval=1, group="Risk Management")

// Trailing Stop
i_trailStepR    = input.float(0.1, "Trail Step per Bar (R)", minval=0.01, maxval=1.0, step=0.01, group="Trailing Stop", tooltip="SL moves this many R toward price on each candle close")
i_beR           = input.float(0.2, "Move to Breakeven at (R)", minval=0.01, maxval=2.0, step=0.01, group="Trailing Stop", tooltip="When price reaches this R in profit, SL moves to entry")

// Time Filter
i_startHour = input.int(9, "Start Hour (NY)", minval=0, maxval=23, group="Time Filter")
i_startMin  = input.int(30, "Start Minute (NY)", minval=0, maxval=59, group="Time Filter")
i_endHour   = input.int(12, "End Hour (NY)", minval=0, maxval=23, group="Time Filter")
i_endMin    = input.int(0, "End Minute (NY)", minval=0, maxval=59, group="Time Filter")

// Advanced
i_reversalLookback = input.int(30, "Reversal SL Lookback (bars)", minval=5, maxval=120, group="Advanced", tooltip="Number of bars to look back for HH/LL when calculating Setup 2 stop loss")
i_minContracts     = input.int(40, "Min Contracts (widens SL to fit)", minval=0, maxval=100, group="Advanced", tooltip="If the SL is too tight, widen it so at least this many contracts fit. 0 = disabled. Calculates min SL from instrument point value.")
i_minInversionPct  = input.float(50.0, "Min Inversion Depth (% of FVG)", minval=0, maxval=200, step=10, group="Advanced", tooltip="Close must exceed the FVG boundary by this % of the zone width. 0 = just beyond edge, 50 = half a zone-width past, 100 = full zone-width past.")

// Blocked Dates
i_useBlockedDates = input.bool(true, "Enable Blocked Dates", group="Blocked Dates")
i_blockedDates    = input.string("1225,0101,0704", "Blocked Dates (MMDD)", group="Blocked Dates")

// Visuals
i_showFVGBox    = input.bool(true, "Show FVG Box", group="Visuals")
i_showSLTP      = input.bool(true, "Show SL/TP Lines", group="Visuals")
i_showLabels    = input.bool(true, "Show Setup Labels", group="Visuals")

// Webhook
i_enableWebhook = input.bool(false, "Enable Webhook Alerts", group="Webhook")
i_webhookSymbol = input.string("", "Symbol Override", group="Webhook", tooltip="Leave empty to use chart symbol")

// ══════════════════════════════════════════════════════════════════════════════
// CONSTANTS & HELPERS
// ══════════════════════════════════════════════════════════════════════════════

// States
STATE_WAIT_OPEN = 0
STATE_SCAN_FVG  = 1
STATE_FVG_FOUND = 2
STATE_IN_TRADE  = 3
STATE_DONE      = 4

fmt(v) => str.tostring(v, format.mintick)

// NY timezone helpers
nyHour = hour(time, "America/New_York")
nyMin  = minute(time, "America/New_York")

// Current bar is within trading window
nyTimeInMinutes = nyHour * 60 + nyMin
startInMinutes  = i_startHour * 60 + i_startMin
endInMinutes    = i_endHour * 60 + i_endMin
inWindow = nyTimeInMinutes >= startInMinutes and nyTimeInMinutes < endInMinutes

// Blocked dates check
currentMonth = month(time, "America/New_York")
currentDay   = dayofmonth(time, "America/New_York")
currentMMDD  = str.tostring(currentMonth, "00") + str.tostring(currentDay, "00")
isBlockedDate = i_useBlockedDates ? str.contains(i_blockedDates, currentMMDD) : false

// New day detection (NY timezone)
nyDayNum = dayofmonth(time, "America/New_York")
newDay = ta.change(nyDayNum) != 0

// ══════════════════════════════════════════════════════════════════════════════
// STATE VARIABLES (reset daily)
// ══════════════════════════════════════════════════════════════════════════════

var int   state = STATE_WAIT_OPEN

// First FVG data
var int   fvgDir        = 0       // +1 bullish, -1 bearish
var float fvgZoneHi     = na      // top of FVG zone
var float fvgZoneLo     = na      // bottom of FVG zone
var float fvgCandle1Hi  = na
var float fvgCandle1Lo  = na
var float fvgCandle2Hi  = na
var float fvgCandle2Lo  = na
var float fvgCandle3Hi  = na
var float fvgCandle3Lo  = na
var int   fvgBarIdx     = na      // bar_index when FVG detected
var float fvgFormHH     = na      // highest high of 3-candle formation
var float fvgFormLL     = na      // lowest low of 3-candle formation

// Post-FVG tracking
var bool  fvgTapped     = false
var int   fvgTapBar     = na      // bar_index when first tapped

// Trade data
var int   setupTriggered = 0
var float entryPrice    = na
var float stopLoss      = na
var float initialSL     = na      // original SL distance for R calculations
var int   tradeDir      = 0       // +1 long, -1 short
var bool  tradedToday   = false
var bool  atBreakeven   = false
var int   tradeEntryBar = na

// FVG box visual
var box   fvgBox        = na

// State cascade guard
var int   stateAtBarStart = STATE_WAIT_OPEN

// Trade visual lines
var line slLine         = na
var line entryLine      = na


// ══════════════════════════════════════════════════════════════════════════════
// DAILY RESET
// ══════════════════════════════════════════════════════════════════════════════

if newDay
    state          := STATE_WAIT_OPEN
    fvgDir         := 0
    fvgZoneHi      := na
    fvgZoneLo      := na
    fvgCandle1Hi   := na
    fvgCandle1Lo   := na
    fvgCandle2Hi   := na
    fvgCandle2Lo   := na
    fvgCandle3Hi   := na
    fvgCandle3Lo   := na
    fvgBarIdx      := na
    fvgFormHH      := na
    fvgFormLL      := na
    fvgTapped      := false
    fvgTapBar      := na
    setupTriggered := 0
    entryPrice     := na
    stopLoss       := na
    initialSL      := na
    tradeDir       := 0
    tradedToday    := false
    atBreakeven    := false
    tradeEntryBar  := na
    fvgBox         := na
    stateAtBarStart := STATE_WAIT_OPEN
    slLine         := na
    entryLine      := na

// ══════════════════════════════════════════════════════════════════════════════
// FVG DETECTION (standard 3-candle)
// ══════════════════════════════════════════════════════════════════════════════

isBullFVG = low > high[2]
isBearFVG = high < low[2]

// FVG session timing: require the displacement candle (c2, bar [1]) to be at or after session start.
// This blocks pre-market FVGs but allows the 9:30 candle to be c2 (the big move).
candle2Hour = hour(time[1], "America/New_York")
candle2Min  = minute(time[1], "America/New_York")
candle2TimeInMin = candle2Hour * 60 + candle2Min
fvgSessionValid = candle2TimeInMin >= startInMinutes

// ══════════════════════════════════════════════════════════════════════════════
// POSITION SIZING
// ══════════════════════════════════════════════════════════════════════════════

calcOrderQty(entryP, stopP) =>
    qty = 0
    if i_sizeMode == "Fixed contracts"
        qty := i_fixedContracts
    else
        riskCash = i_sizeMode == "Fixed $" ? i_riskDollars : (strategy.equity * i_riskPct / 100.0)
        riskPerContract = math.abs(entryP - stopP) * syminfo.pointvalue
        qty := riskPerContract > 0 ? math.max(math.floor(riskCash / riskPerContract), 1) : 1
    qty

// ══════════════════════════════════════════════════════════════════════════════
// MIN SL ADJUSTMENT: Widen SL if too tight for min contracts
// Min SL = risk_dollars / (min_contracts * point_value)
// ══════════════════════════════════════════════════════════════════════════════

minSLDist() =>
    if i_minContracts > 0 and i_sizeMode != "Fixed contracts"
        riskCash = i_sizeMode == "Fixed $" ? i_riskDollars : (strategy.equity * i_riskPct / 100.0)
        riskCash / (i_minContracts * syminfo.pointvalue)
    else
        0.0

adjustSL(entryP, rawSL, isLong) =>
    float sl = rawSL
    minDist = minSLDist()
    if minDist > 0
        currentDist = math.abs(entryP - rawSL)
        if currentDist < minDist
            sl := isLong ? entryP - minDist : entryP + minDist
    sl

// ══════════════════════════════════════════════════════════════════════════════
// HELPER: Find highest high / lowest low over N bars back
// ══════════════════════════════════════════════════════════════════════════════

highestInRange(n) =>
    float hh = high
    for i = 1 to n - 1
        if high[i] > hh
            hh := high[i]
    hh

lowestInRange(n) =>
    float ll = low
    for i = 1 to n - 1
        if low[i] < ll
            ll := low[i]
    ll

// Helper: highest high / lowest low from fvgTapBar to current bar
highestSinceTap() =>
    float hh = high
    barsBack = bar_index - fvgTapBar
    if barsBack > 0
        for i = 1 to barsBack
            if high[i] > hh
                hh := high[i]
    hh

lowestSinceTap() =>
    float ll = low
    barsBack = bar_index - fvgTapBar
    if barsBack > 0
        for i = 1 to barsBack
            if low[i] < ll
                ll := low[i]
    ll

// ══════════════════════════════════════════════════════════════════════════════
// STATE MACHINE
// ══════════════════════════════════════════════════════════════════════════════

// Track previous state to prevent cascading (Pine doesn't have elif at top level)
stateAtBarStart := state

// --- STATE 0: Wait for session open ---
if state == STATE_WAIT_OPEN
    if inWindow and not isBlockedDate
        state := STATE_SCAN_FVG

// --- STATE 1: Scan for first valid FVG ---
if state == STATE_SCAN_FVG and inWindow and not isBlockedDate
    if isBullFVG and fvgSessionValid
        fvgDir       := 1
        fvgZoneHi    := low        // top of bullish FVG = current low
        fvgZoneLo    := high[2]    // bottom of bullish FVG = candle 1 high
        fvgCandle1Hi := high[2]
        fvgCandle1Lo := low[2]
        fvgCandle2Hi := high[1]
        fvgCandle2Lo := low[1]
        fvgCandle3Hi := high
        fvgCandle3Lo := low
        fvgBarIdx    := bar_index
        fvgFormHH    := math.max(high[2], high[1], high)
        fvgFormLL    := math.min(low[2], low[1], low)
        state        := STATE_FVG_FOUND
        if i_showFVGBox
            fvgBox := box.new(bar_index[2], fvgZoneHi, bar_index, fvgZoneLo, border_color=color.new(color.teal, 30), bgcolor=color.new(color.teal, 85))
    else if isBearFVG and fvgSessionValid
        fvgDir       := -1
        fvgZoneHi    := low[2]     // top of bearish FVG = candle 1 low
        fvgZoneLo    := high       // bottom of bearish FVG = current high
        fvgCandle1Hi := high[2]
        fvgCandle1Lo := low[2]
        fvgCandle2Hi := high[1]
        fvgCandle2Lo := low[1]
        fvgCandle3Hi := high
        fvgCandle3Lo := low
        fvgBarIdx    := bar_index
        fvgFormHH    := math.max(high[2], high[1], high)
        fvgFormLL    := math.min(low[2], low[1], low)
        state        := STATE_FVG_FOUND
        if i_showFVGBox
            fvgBox := box.new(bar_index[2], fvgZoneHi, bar_index, fvgZoneLo, border_color=color.new(color.red, 30), bgcolor=color.new(color.red, 85))

// --- STATE 2: FVG found, monitor for setups ---
// Only run if we were already in FVG_FOUND at bar start (prevents cascading from SCAN on same bar)
if state == STATE_FVG_FOUND and stateAtBarStart == STATE_FVG_FOUND and not tradedToday

    // Extend FVG box visually
    if not na(fvgBox)
        box.set_right(fvgBox, bar_index)

    // Track if FVG has been tapped (price enters the zone)
    // Only check after the formation bar (bar_index > fvgBarIdx) so formation candles don't count as a tap
    if not fvgTapped and bar_index > fvgBarIdx
        if fvgDir == 1 and low <= fvgZoneHi   // price dips into bullish FVG from above
            fvgTapped := true
            fvgTapBar := bar_index
        if fvgDir == -1 and high >= fvgZoneLo  // price reaches up into bearish FVG from below
            fvgTapped := true
            fvgTapBar := bar_index

    // ─── SETUP 1: Double Gap ─────────────────────────────────────────────
    // Second consecutive FVG in same direction
    if i_enableSetup1 and setupTriggered == 0
        setup1Long  = fvgDir == 1 and isBullFVG and bar_index > fvgBarIdx
        setup1Short = fvgDir == -1 and isBearFVG and bar_index > fvgBarIdx
        if setup1Long
            entryPrice := close
            stopLoss   := adjustSL(close, fvgCandle1Lo, true)
            if entryPrice > stopLoss
                initialSL  := entryPrice - stopLoss
                tradeDir   := 1
                setupTriggered := 1
                state      := STATE_IN_TRADE
        if setup1Short and setupTriggered == 0
            entryPrice := close
            stopLoss   := adjustSL(close, fvgCandle1Hi, false)
            if entryPrice < stopLoss
                initialSL  := stopLoss - entryPrice
                tradeDir   := -1
                setupTriggered := 1
                state      := STATE_IN_TRADE

    // ─── SETUP 2: Reversal ───────────────────────────────────────────────
    // First FVG is inverted (candle closes beyond FVG in opposing direction)
    if i_enableSetup2 and setupTriggered == 0
        zoneWidth = fvgZoneHi - fvgZoneLo
        invBuffer = zoneWidth * i_minInversionPct / 100.0
        // Bullish FVG inverted: candle closes below the bottom of the FVG zone (with inversion depth filter)
        setup2Short = fvgDir == 1 and close < fvgZoneLo - invBuffer and bar_index > fvgBarIdx
        // Bearish FVG inverted: candle closes above the top of the FVG zone (with inversion depth filter)
        setup2Long  = fvgDir == -1 and close > fvgZoneHi + invBuffer and bar_index > fvgBarIdx
        if setup2Long
            entryPrice := close
            // Find most recent swing low (3-bar pivot)
            float swingLow = na
            for i = 1 to 50
                if low[i] < low[i+1] and low[i] < low[i-1]
                    swingLow := low[i]
                    break
            stopLoss := not na(swingLow) ? adjustSL(close, swingLow, true) : adjustSL(close, lowestInRange(i_reversalLookback), true)
            if not na(stopLoss) and entryPrice > stopLoss
                initialSL  := entryPrice - stopLoss
                tradeDir   := 1
                setupTriggered := 2
                state      := STATE_IN_TRADE
        if setup2Short and setupTriggered == 0
            entryPrice := close
            // Find most recent swing high (3-bar pivot)
            float swingHigh = na
            for i = 1 to 50
                if high[i] > high[i+1] and high[i] > high[i-1]
                    swingHigh := high[i]
                    break
            stopLoss := not na(swingHigh) ? adjustSL(close, swingHigh, false) : adjustSL(close, highestInRange(i_reversalLookback), false)
            if not na(stopLoss) and entryPrice < stopLoss
                initialSL  := stopLoss - entryPrice
                tradeDir   := -1
                setupTriggered := 2
                state      := STATE_IN_TRADE

    // ─── SETUP 3: Continuation (FVG tapped + CISD) ──────────────────────
    // FVG tapped but NOT inverted, then CISD confirms continuation
    if i_enableSetup3 and setupTriggered == 0 and fvgTapped and bar_index > fvgBarIdx
        // Check FVG is NOT inverted
        bullFvgNotInverted = fvgDir == 1 and close >= fvgZoneLo
        bearFvgNotInverted = fvgDir == -1 and close <= fvgZoneHi

        // CISD detection (body-based, ignore wicks)
        prevIsBearish = close[1] < open[1]
        bullishCISD   = prevIsBearish and close > open[1]
        prevIsBullish = close[1] > open[1]
        bearishCISD   = prevIsBullish and close < open[1]

        if fvgDir == 1 and bullFvgNotInverted and bullishCISD
            entryPrice := close
            stopLoss   := adjustSL(close, lowestSinceTap(), true)
            if entryPrice > stopLoss
                initialSL  := entryPrice - stopLoss
                tradeDir   := 1
                setupTriggered := 3
                state      := STATE_IN_TRADE
        if fvgDir == -1 and bearFvgNotInverted and bearishCISD and setupTriggered == 0
            entryPrice := close
            stopLoss   := adjustSL(close, highestSinceTap(), false)
            if entryPrice < stopLoss
                initialSL  := stopLoss - entryPrice
                tradeDir   := -1
                setupTriggered := 3
                state      := STATE_IN_TRADE

    // ─── SETUP 4: Tap & Engulf ───────────────────────────────────────────
    // FVG tapped, then candle closes beyond the full 3-candle formation (wicks included)
    if i_enableSetup4 and setupTriggered == 0 and fvgTapped and bar_index > fvgBarIdx
        setup4Long  = fvgDir == 1 and close > fvgFormHH
        setup4Short = fvgDir == -1 and close < fvgFormLL
        if setup4Long
            entryPrice := close
            stopLoss   := adjustSL(close, lowestSinceTap(), true)
            if entryPrice > stopLoss
                initialSL  := entryPrice - stopLoss
                tradeDir   := 1
                setupTriggered := 4
                state      := STATE_IN_TRADE
        if setup4Short and setupTriggered == 0
            entryPrice := close
            stopLoss   := adjustSL(close, highestSinceTap(), false)
            if entryPrice < stopLoss
                initialSL  := stopLoss - entryPrice
                tradeDir   := -1
                setupTriggered := 4
                state      := STATE_IN_TRADE

    // Window expired without a setup
    if not inWindow and state == STATE_FVG_FOUND
        state := STATE_DONE

// ══════════════════════════════════════════════════════════════════════════════
// ORDER EXECUTION (on state transition to IN_TRADE)
// ══════════════════════════════════════════════════════════════════════════════

if state == STATE_IN_TRADE and not tradedToday and strategy.position_size == 0
    qty = calcOrderQty(entryPrice, stopLoss)
    setupNames = array.from("", "Double Gap", "Reversal", "Continuation", "Tap & Engulf")
    setupName = array.get(setupNames, setupTriggered)
    if qty > 0
        if tradeDir == 1
            strategy.entry("LONG_S" + str.tostring(setupTriggered), strategy.long, qty=qty)
            strategy.exit("LONG_EXIT", from_entry="LONG_S" + str.tostring(setupTriggered), stop=stopLoss)
        else
            strategy.entry("SHORT_S" + str.tostring(setupTriggered), strategy.short, qty=qty)
            strategy.exit("SHORT_EXIT", from_entry="SHORT_S" + str.tostring(setupTriggered), stop=stopLoss)
        tradedToday   := true
        tradeEntryBar := bar_index

        // SL/Entry lines
        if i_showSLTP
            slLine    := line.new(bar_index, stopLoss, bar_index + 1, stopLoss, color=color.new(color.fuchsia, 0), width=2, style=line.style_solid)
            entryLine := line.new(bar_index, entryPrice, bar_index + 1, entryPrice, color=color.new(color.white, 30), width=1, style=line.style_dashed)

        // Labels
        if i_showLabels
            dirText = tradeDir == 1 ? "LONG" : "SHORT"
            labelText = "S" + str.tostring(setupTriggered) + ": " + setupName + "\n" + dirText + " @ " + fmt(entryPrice) + "\nSL: " + fmt(stopLoss) + " | Trail: " + str.tostring(i_trailStepR, "#.##") + "R/bar"
            labelColor = tradeDir == 1 ? color.teal : color.red
            labelStyle = tradeDir == 1 ? label.style_label_up : label.style_label_down
            labelLoc   = tradeDir == 1 ? yloc.belowbar : yloc.abovebar
            label.new(bar_index, na, text=labelText, style=labelStyle, color=labelColor, textcolor=color.white, size=size.small, yloc=labelLoc)

        // Webhook alert
        if i_enableWebhook
            sym = str.length(i_webhookSymbol) > 0 ? i_webhookSymbol : syminfo.ticker
            action = tradeDir == 1 ? "buy" : "sell"
            slDist = math.abs(entryPrice - stopLoss)
            riskPerContract = slDist * syminfo.pointvalue
            totalRisk = riskPerContract * qty
            alertMsg = '{"action":"' + action + '","symbol":"' + sym + '","setup":"' + setupName + '","contracts":' + str.tostring(qty) + ',"entry":' + fmt(entryPrice) + ',"sl":' + fmt(stopLoss) + ',"riskPerContract":' + str.tostring(riskPerContract, "#.##") + ',"totalRisk":' + str.tostring(totalRisk, "#.##") + ',"strategy":"etrades_scalp_trailing"}'
            alert(alertMsg, alert.freq_once_per_bar_close)

        // Standard alert
        alert("ETrades Scalp [Trail]: S" + str.tostring(setupTriggered) + " " + setupName + " " + (tradeDir == 1 ? "LONG" : "SHORT") + " @ " + fmt(entryPrice) + " SL=" + fmt(stopLoss), alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════════
// TRAILING STOP LOGIC (runs each bar while in trade)
// ══════════════════════════════════════════════════════════════════════════════

if state == STATE_IN_TRADE and tradedToday and strategy.position_size != 0 and not na(initialSL)
    trailStep = initialSL * i_trailStepR  // 0.1R in price terms
    beDist    = initialSL * i_beR          // 0.2R in price terms

    if tradeDir == 1
        currentProfit = close - entryPrice
        // Breakeven check: if price reached 0.2R, lock SL to entry
        if not atBreakeven and currentProfit >= beDist
            atBreakeven := true
            if stopLoss < entryPrice
                stopLoss := entryPrice
        // Trail: move SL up by 0.1R per bar, but never move it back down
        if atBreakeven
            newSL = stopLoss + trailStep
            // Don't trail above current close (would immediately stop out)
            if newSL < close
                stopLoss := newSL
    else
        currentProfit = entryPrice - close
        // Breakeven check
        if not atBreakeven and currentProfit >= beDist
            atBreakeven := true
            if stopLoss > entryPrice
                stopLoss := entryPrice
        // Trail: move SL down by 0.1R per bar, but never move it back up
        if atBreakeven
            newSL = stopLoss - trailStep
            // Don't trail below current close
            if newSL > close
                stopLoss := newSL

    // Update the exit order with new SL
    if tradeDir == 1
        strategy.exit("LONG_EXIT", from_entry="LONG_S" + str.tostring(setupTriggered), stop=stopLoss)
    else
        strategy.exit("SHORT_EXIT", from_entry="SHORT_S" + str.tostring(setupTriggered), stop=stopLoss)

// Transition to DONE when position closes (skip entry bar — position_size is still 0 due to process_orders_on_close)
if state == STATE_IN_TRADE and tradedToday and strategy.position_size == 0 and bar_index > nz(tradeEntryBar, 0)
    state := STATE_DONE

// If window expires while scanning and no FVG found
if state == STATE_SCAN_FVG and not inWindow
    state := STATE_DONE

// ══════════════════════════════════════════════════════════════════════════════
// VISUALS
// ══════════════════════════════════════════════════════════════════════════════

// Extend and update SL/Entry lines while trade is active
if state == STATE_IN_TRADE and tradedToday and i_showSLTP
    if not na(slLine)
        line.set_x2(slLine, bar_index)
        line.set_y1(slLine, stopLoss)
        line.set_y2(slLine, stopLoss)
    if not na(entryLine)
        line.set_x2(entryLine, bar_index)

// Background: dim outside trading window
bgcolor(not inWindow ? color.new(color.gray, 93) : na)


// ══════════════════════════════════════════════════════════════════════════════
// ALERT CONDITIONS
// ══════════════════════════════════════════════════════════════════════════════

alertcondition(state == STATE_FVG_FOUND and state[1] == STATE_SCAN_FVG, "FVG Detected", "ETrades Scalp: First FVG detected")
alertcondition(setupTriggered == 1 and setupTriggered[1] == 0, "Setup 1: Double Gap", "ETrades Scalp: Double Gap triggered")
alertcondition(setupTriggered == 2 and setupTriggered[1] == 0, "Setup 2: Reversal", "ETrades Scalp: Reversal triggered")
alertcondition(setupTriggered == 3 and setupTriggered[1] == 0, "Setup 3: Continuation", "ETrades Scalp: Continuation triggered")
alertcondition(setupTriggered == 4 and setupTriggered[1] == 0, "Setup 4: Tap & Engulf", "ETrades Scalp: Tap & Engulf triggered")
